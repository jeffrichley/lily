    {"type":"text","id":"artifact_rules_t","x":96,"y":960,"width":416,"height":160,"text":"RULES evidence\n1) no plan, no code\n2) execute from plan in order\n3) patch plan when wrong\n4) validate meaningful changes\n5) non-negotiables: no silent fallbacks,\n   no direct main commits, no boundary breaks\n\nOutput convention\nplans -> .ai/PLANS/<NNN>-<feature>.md","originalText":"RULES evidence\n1) no plan, no code\n2) execute from plan in order\n3) patch plan when wrong\n4) validate meaningful changes\n5) non-negotiables: no silent fallbacks,\n   no direct main commits, no boundary breaks\n\nOutput convention\nplans -> .ai/PLANS/<NNN>-<feature>.md","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#2ECC71","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":502023,"version":1,"versionNonce":502123,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

